#!/usr/bin/env bash
#
# uruncode - run Claude Code or Codex CLI through the UrunAI gateway.
#
set -euo pipefail

APP_NAME="uruncode"
DEFAULT_BASE_URL="https://api.urunai.my.id/v1"
DEFAULT_MODEL_CLAUDE="claude-haiku-4-5-20251001"
DEFAULT_MODEL_CODEX="gpt-5.4-mini"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/uruncode"
CONFIG_FILE="$CONFIG_DIR/config"

say() { printf '%s\n' "$*" >&2; }

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

save_key() {
  local key
  key="$(trim "$1")"
  if [ -z "$key" ]; then
    say "Refusing to save an empty key."
    return 1
  fi
  mkdir -p "$CONFIG_DIR"
  ( umask 077; printf 'URUNAI_API_KEY=%s\n' "$key" > "$CONFIG_FILE" )
  chmod 600 "$CONFIG_FILE"
  say "Key saved to $CONFIG_FILE"
}

read_key() {
  [ -f "$CONFIG_FILE" ] || return 0
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      URUNAI_API_KEY=*) printf '%s' "${line#URUNAI_API_KEY=}"; return 0 ;;
    esac
  done < "$CONFIG_FILE"
  return 0
}

backup_file_once() {
  local source="$1" name="$2"
  local backup_dir="$CONFIG_DIR/backups"
  local backup_file="$backup_dir/$name"
  local missing_file="$backup_file.missing"
  if [ -f "$backup_file" ] || [ -f "$missing_file" ]; then
    return 0
  fi
  mkdir -p "$backup_dir"
  if [ -f "$source" ]; then
    cp -p "$source" "$backup_file"
  else
    : > "$missing_file"
  fi
}

restore_backup_file() {
  local target="$1" name="$2"
  local backup_dir="$CONFIG_DIR/backups"
  local backup_file="$backup_dir/$name"
  local missing_file="$backup_file.missing"
  if [ -f "$backup_file" ]; then
    mkdir -p "$(dirname "$target")"
    cp -p "$backup_file" "$target"
    rm -f "$backup_file"
    say "Restored $target"
  elif [ -f "$missing_file" ]; then
    rm -f "$target"
    rm -f "$missing_file"
    say "Removed $target; it did not exist before uruncode."
  fi
}

restore_config_backups() {
  local claude_settings="$HOME/.claude/settings.json"
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  restore_backup_file "$claude_settings" "claude-settings.json"
  restore_backup_file "$codex_home/config.toml" "codex-config.toml"
  restore_backup_file "$codex_home/uruncode.config.toml" "codex-uruncode.config.toml"
  rmdir "$CONFIG_DIR/backups" 2>/dev/null || true
}

read_secret() {
  local prompt="$1" value=""
  printf '%s' "$prompt" >&2
  if IFS= read -rs value 2>/dev/null < /dev/tty; then
    :
  else
    IFS= read -rs value || true
  fi
  printf '\n' >&2
  printf '%s' "$value"
}

interactive_setup() {
  say ""
  say "+------------------------------------------+"
  say "|  uruncode - first-time setup             |"
  say "+------------------------------------------+"
  say ""
  say "Claude Code and Codex CLI will run through UrunAI."
  say "You only need to enter your UrunAI API key once."
  say ""
  local key="" tries=0
  while :; do
    key="$(trim "$(read_secret 'UrunAI API key: ')")"
    [ -n "$key" ] && break
    tries=$((tries + 1))
    say "Key can't be empty."
    if [ "$tries" -ge 3 ]; then
      say "Aborting after 3 empty attempts."
      exit 1
    fi
  done
  save_key "$key"
  say ""
}

resolve_key() {
  local key
  key="$(read_key)"
  if [ -z "${key:-}" ] && [ -n "${URUNAI_API_KEY:-}" ]; then
    key="$(trim "$URUNAI_API_KEY")"
    say "Using URUNAI_API_KEY from environment; saving for next time."
    save_key "$key" || true
  fi
  if [ -z "${key:-}" ]; then
    interactive_setup
    key="$(read_key)"
  fi
  if [ -z "${key:-}" ]; then
    say "No API key available. Run '$APP_NAME config' to set one."
    exit 1
  fi
  printf '%s' "$key"
}

show_help() {
  cat >&2 <<'EOF'
Usage:
  uruncode                  Choose Claude Code or Codex CLI interactively
  uruncode claude [ARGS...] Run Claude Code through UrunAI
  uruncode codex [ARGS...]  Run Codex CLI through UrunAI
  uruncode config [KEY]     Save or replace the UrunAI API key
  uruncode reset            Restore CLI config backups and delete the stored API key
  uruncode update           Re-run the installer

Environment overrides:
  URUNAI_API_KEY       API key to save/use
  URUNAI_BASE_URL      Gateway base URL
  URUNAI_CLAUDE_MODEL  Claude Code model alias
  URUNAI_CODEX_MODEL   Codex CLI model alias
EOF
}

choose_launcher() {
  say ""
  say "Choose a launcher:"
  say "  1) Claude Code"
  say "  2) Codex CLI"
  say ""
  local choice=""
  printf 'Selection [1-2]: ' >&2
  if IFS= read -r choice 2>/dev/null < /dev/tty; then
    :
  else
    IFS= read -r choice || true
  fi
  case "$(trim "$choice")" in
    1|claude|Claude) printf 'claude' ;;
    2|codex|Codex) printf 'codex' ;;
    *) say "Invalid selection."; exit 1 ;;
  esac
}

ensure_codex_profile() {
  local base_url="$1" model="$2"
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local profile_file="$codex_home/uruncode.config.toml"
  backup_file_once "$codex_home/config.toml" "codex-config.toml"
  backup_file_once "$profile_file" "codex-uruncode.config.toml"
  mkdir -p "$codex_home"
  cat > "$profile_file" <<EOF
model = "$model"
model_provider = "urunai"

[model_providers.urunai]
name = "UrunAI"
base_url = "$base_url"
wire_api = "responses"
env_key = "URUNAI_API_KEY"
EOF
}

ensure_claude_settings() {
  local base_url="$1" key="$2"
  local settings_dir="$HOME/.claude"
  local settings_file="$settings_dir/settings.json"
  backup_file_once "$settings_file" "claude-settings.json"
  mkdir -p "$settings_dir"
  BASE_URL="$base_url" AUTH_TOKEN="$key" SETTINGS_FILE="$settings_file" node -e '
const fs = require("fs");
const file = process.env.SETTINGS_FILE;
let content = {};
if (fs.existsSync(file)) {
  try { content = JSON.parse(fs.readFileSync(file, "utf8")); } catch { content = {}; }
}
content.env = { ...(content.env || {}), ANTHROPIC_BASE_URL: process.env.BASE_URL, ANTHROPIC_AUTH_TOKEN: process.env.AUTH_TOKEN };
fs.writeFileSync(file, JSON.stringify(content, null, 2) + "\n", "utf8");
'
}

run_claude() {
  local key="$1"
  shift
  if ! command -v claude >/dev/null 2>&1; then
    say "claude CLI not found on PATH."
    say "Install Claude Code first: https://docs.claude.com/en/docs/claude-code"
    exit 127
  fi

  local base_url="${URUNAI_BASE_URL:-$DEFAULT_BASE_URL}"
  local model="${URUNAI_CLAUDE_MODEL:-$DEFAULT_MODEL_CLAUDE}"
  export ANTHROPIC_BASE_URL="$base_url"
  export ANTHROPIC_AUTH_TOKEN="$key"
  ensure_claude_settings "$base_url" "$key"

  exec claude "$@"
}

run_codex() {
  local key="$1"
  shift
  if ! command -v codex >/dev/null 2>&1; then
    say "codex CLI not found on PATH."
    say "Install Codex CLI first: https://developers.openai.com/codex"
    exit 127
  fi

  local base_url="${URUNAI_BASE_URL:-$DEFAULT_BASE_URL}"
  local model="${URUNAI_CODEX_MODEL:-$DEFAULT_MODEL_CODEX}"
  ensure_codex_profile "$base_url" "$model"
  export URUNAI_API_KEY="$key"

  if [ "${1:-}" != "" ] && [ -d "$1" ]; then
    local target="$1"
    shift
    exec codex --profile uruncode --cd "$target" "$@"
  fi
  exec codex --profile uruncode "$@"
}

case "${1:-}" in
  config|--config|set-key|--set-key|change|--change|change-key|--change-key)
    if [ "${2:-}" != "" ]; then
      save_key "$2"
    else
      interactive_setup
    fi
    say "Done. Run '$APP_NAME' to start."
    exit 0
    ;;
  reset|--reset)
    restore_config_backups
    rm -f "$CONFIG_FILE"
    say "Stored key removed."
    exit 0
    ;;
  update|--update|upgrade|--upgrade)
    say "Updating $APP_NAME to the latest version..."
    curl -fsSL "${URUNCODE_INSTALL_URL:-https://raw.githubusercontent.com/nugrahadevelopers/uruncode/main/install.sh}" | bash
    exit $?
    ;;
  help|--help|-h)
    show_help
    exit 0
    ;;
esac

launcher="${1:-}"
if [ -z "$launcher" ]; then
  launcher="$(choose_launcher)"
else
  shift
fi

key="$(resolve_key)"

case "$launcher" in
  claude|cc)
    run_claude "$key" "$@"
    ;;
  codex|cx)
    run_codex "$key" "$@"
    ;;
  *)
    say "Unknown launcher: $launcher"
    show_help
    exit 1
    ;;
esac
